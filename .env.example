# ─────────────── PostgreSQL / TimescaleDB ───────────────
POSTGRES_USER=bquant
POSTGRES_PASSWORD=bquant_secret
POSTGRES_DB=bquant
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://bquant:bquant_secret@db:5432/bquant
DATABASE_URL_SYNC=postgresql://bquant:bquant_secret@db:5432/bquant

# ─────────────── Redis ───────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─────────────── API ─────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
DEBUG=true

# ─────────────── Jupyter ─────────────────────────────────
JUPYTER_TOKEN=bquant-jupyter-token

# ─────────────── External Data APIs ─────────────────────
# Get free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo
# Optional — leave blank to use default endpoints
OPENBB_PAT=
